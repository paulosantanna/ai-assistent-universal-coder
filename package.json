{
  "scripts": {
    "aeos:bootstrap": "python aeos/scripts/bootstrap_portable.py",
    "aeos:bootstrap:deps": "python aeos/scripts/bootstrap_portable.py --install-deps",
    "aeos:verify": "python aeos/scripts/verify.py --suite quick",
    "aeos:verify:full": "python aeos/scripts/verify.py --suite full",
    "test:python": "python aeos/scripts/test_matrix.py --only python-pytest",
    "test:python:cov": "python aeos/scripts/run_portable_python.py --require-module pytest -- -m pytest --cov=aeos --cov-report=term-missing",
    "test:python:bdd": "python aeos/scripts/test_matrix.py --only python-behave",
    "test:robot": "python aeos/scripts/test_matrix.py --only python-robot",
    "test:node:jest": "jest --config jest.config.cjs",
    "test:node:vitest": "vitest run --config vitest.config.ts",
    "test:node:mocha": "mocha \"tests/node/**/*.test.cjs\"",
    "test:node:cucumber": "cucumber-js --config cucumber.js",
    "test:java:maven": ".tools/bin/mvn -f templates/test-toolchains/java-junit5/pom.xml test",
    "test:java:gradle": ".tools/bin/gradle --no-daemon -p templates/test-toolchains/java-gradle-junit5 test",
    "test:java": "npm run test:java:maven && npm run test:java:gradle",
    "test:matrix": "python aeos/scripts/test_matrix.py",
    "test:matrix:full": "npm run test:matrix -- --include-optional",
    "test:all": "npm run test:python && npm run test:python:bdd && npm run test:robot && npm run test:node:jest && npm run test:node:vitest && npm run test:node:mocha && npm run test:node:cucumber && npm run test:java"
  },
  "devDependencies": {
    "@cucumber/cucumber": "^13.0.0",
    "@modelcontextprotocol/inspector-cli": "^0.22.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.1",
    "c8": "^11.0.0",
    "jest": "^30.4.2",
    "mocha": "^11.7.6",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
