{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeos.dev/schemas/spec-driven/spec.schema.json",
  "title": "AEOS Driven Specification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "slug", "objective", "revision", "status", "requirements", "acceptanceCriteria", "outOfScope", "risks", "createdAt", "updatedAt"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "objective": { "type": "string", "minLength": 1 },
    "revision": { "type": "integer", "minimum": 1 },
    "status": { "enum": ["draft", "ready", "approved", "implementing", "verifying", "accepted", "rejected"] },
    "requirements": { "type": "array", "items": { "$ref": "#/$defs/requirement" } },
    "acceptanceCriteria": { "type": "array", "items": { "$ref": "#/$defs/criterion" } },
    "outOfScope": { "type": "array", "items": { "type": "string" } },
    "risks": { "type": "array", "items": { "type": "string" } },
    "approval": { "$ref": "#/$defs/approval" },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  },
  "$defs": {
    "requirement": { "type": "object", "additionalProperties": false, "required": ["id", "statement", "priority"], "properties": { "id": { "type": "string", "pattern": "^REQ-[0-9]{3}$" }, "statement": { "type": "string", "minLength": 1 }, "priority": { "enum": ["must", "should", "could"] } } },
    "criterion": { "type": "object", "additionalProperties": false, "required": ["id", "requirementIds", "statement", "verification"], "properties": { "id": { "type": "string", "pattern": "^AC-[0-9]{3}$" }, "requirementIds": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "pattern": "^REQ-[0-9]{3}$" } }, "statement": { "type": "string", "minLength": 1 }, "verification": { "enum": ["test", "inspection", "metric", "manual"] }, "evidence": { "type": "object", "additionalProperties": false, "required": ["passed", "reference", "recordedAt"], "properties": { "passed": { "type": "boolean" }, "reference": { "type": "string", "minLength": 1 }, "recordedAt": { "type": "string", "format": "date-time" } } } } },
    "approval": { "type": "object", "additionalProperties": false, "required": ["actor", "evidenceRef", "normativeHash", "approvedAt"], "properties": { "actor": { "type": "string", "minLength": 1 }, "evidenceRef": { "type": "string", "minLength": 1 }, "normativeHash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }, "approvedAt": { "type": "string", "format": "date-time" } } }
  }
}
