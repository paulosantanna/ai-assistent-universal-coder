{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeos.local/schemas/evidence.schema.json",
  "title": "AEOS Evidence",
  "type": "object",
  "required": [
    "id",
    "type",
    "source",
    "sha256",
    "collected_at",
    "collector",
    "claim"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "enum": [
        "file",
        "command",
        "test",
        "benchmark",
        "diff",
        "review",
        "adr",
        "metric",
        "trace",
        "log"
      ]
    },
    "source": {
      "type": "string",
      "minLength": 1
    },
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "collected_at": {
      "type": "string",
      "format": "date-time"
    },
    "collector": {
      "type": "string",
      "minLength": 1
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "commit": {
      "type": "string"
    },
    "command": {
      "type": "string"
    },
    "exit_code": {
      "type": "integer"
    },
    "redacted": {
      "type": "boolean",
      "default": true
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
