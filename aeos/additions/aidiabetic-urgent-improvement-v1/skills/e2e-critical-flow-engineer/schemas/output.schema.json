{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "E2E Critical Flow Engineer output",
  "type": "object",
  "required": [
    "skill",
    "status",
    "summary",
    "evidence",
    "verification",
    "handoff"
  ],
  "properties": {
    "skill": {
      "const": "e2e-critical-flow-engineer"
    },
    "status": {
      "enum": [
        "PASS",
        "REWORK_REQUIRED",
        "BLOCKED"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "verification": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "handoff": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
