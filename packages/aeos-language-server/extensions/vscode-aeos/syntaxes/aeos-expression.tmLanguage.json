{
  "name": "AEOS Expression",
  "scopeName": "source.aeos-expression",
  "fileTypes": [],
  "patterns": [
    { "include": "#expressions" },
    { "include": "#variables" },
    { "include": "#functions" },
    { "include": "#operators" },
    { "include": "#literals" },
    { "include": "#comments" }
  ],
  "repository": {
    "expressions": {
      "patterns": [
        {
          "begin": "\\$\\{",
          "end": "\\}",
          "name": "meta.interpolation.aeos",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.interpolation.begin.aeos"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.interpolation.end.aeos"
            }
          },
          "patterns": [
            { "include": "$self" }
          ]
        },
        {
          "begin": "\\{\\{",
          "end": "\\}\\}",
          "name": "meta.mustache.aeos",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.mustache.begin.aeos"
            }
          },
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.mustache.end.aeos"
            }
          },
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "variables": {
      "patterns": [
        {
          "match": "\\b(steps|inputs|outputs|context|env|secrets|evidence|artifact|session|config|vars)\\b(?:\\.([a-zA-Z_][a-zA-Z0-9_]*))*",
          "name": "variable.other.object.aeos",
          "captures": {
            "1": {
              "name": "variable.language.aeos"
            },
            "2": {
              "name": "variable.other.property.aeos"
            }
          }
        },
        {
          "match": "\\bstep\\.([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "name": "variable.other.step.aeos",
          "captures": {
            "1": {
              "name": "variable.other.step-name.aeos"
            }
          }
        },
        {
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b(?=\\s*(?::|=))",
          "name": "variable.other.assignment.aeos"
        },
        {
          "match": "\\$([a-zA-Z_][a-zA-Z0-9_]*)",
          "name": "variable.other.dollar.aeos"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(contains|startsWith|endsWith|match|split|join|trim|lower|upper|replace|length|count|sum|avg|min|max|coalesce|default|format|toJson|fromJson|toYaml|fromYaml|base64|hash|uuid|now|timestamp|duration)\\s*\\((?=[^)]*\\))",
          "name": "support.function.builtin.aeos",
          "captures": {
            "1": {
              "name": "entity.name.function.aeos"
            }
          }
        },
        {
          "match": "\\b(if|unless|case|switch|each|map|filter|reduce|sort|groupBy|select|where|orderBy|limit|offset)\\s*\\(?",
          "name": "keyword.control.function.aeos"
        },
        {
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\s*(?=\\()",
          "name": "entity.name.function.aeos"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "\\|>",
          "name": "keyword.operator.pipe.aeos"
        },
        {
          "match": "\\|",
          "name": "keyword.operator.pipe-simple.aeos"
        },
        {
          "match": "\\.\\.\\.",
          "name": "keyword.operator.spread.aeos"
        },
        {
          "match": "->|=>",
          "name": "keyword.operator.arrow.aeos"
        },
        {
          "match": "\\?\\.",
          "name": "keyword.operator.optional-chain.aeos"
        },
        {
          "match": "\\?\\?",
          "name": "keyword.operator.nullish-coalescing.aeos"
        },
        {
          "match": "\\?\\s*:",
          "name": "keyword.operator.ternary.aeos"
        },
        {
          "match": "\\+\\+|--",
          "name": "keyword.operator.increment.aeos"
        },
        {
          "match": "==|!=|<=|>=|<|>",
          "name": "keyword.operator.comparison.aeos"
        },
        {
          "match": "&&|\\|\\||!",
          "name": "keyword.operator.logical.aeos"
        },
        {
          "match": "[+\\-*/%]",
          "name": "keyword.operator.arithmetic.aeos"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.aeos"
        }
      ]
    },
    "literals": {
      "patterns": [
        {
          "match": "\\b(true|false|null|undefined|none|nil|yes|no|on|off)\\b",
          "name": "constant.language.aeos"
        },
        {
          "match": "\\b(\\d+\\.?\\d*)(?:\\s*(kb|mb|gb|tb|ms|s|min|h|d|w|%))?\\b",
          "name": "constant.numeric.aeos",
          "captures": {
            "1": {
              "name": "constant.numeric.value.aeos"
            },
            "2": {
              "name": "keyword.other.unit.aeos"
            }
          }
        },
        {
          "match": "0[xX][0-9a-fA-F]+\\b",
          "name": "constant.numeric.hex.aeos"
        },
        {
          "begin": "\"",
          "end": "\"",
          "name": "string.quoted.double.aeos",
          "patterns": [
            {
              "match": "\\\\[\\\"\\\\nrtbf]|\\\\u[0-9a-fA-F]{4}",
              "name": "constant.character.escape.aeos"
            },
            { "include": "#expressions" }
          ]
        },
        {
          "begin": "'",
          "end": "'",
          "name": "string.quoted.single.aeos",
          "patterns": [
            {
              "match": "\\\\[\\'\\\\]",
              "name": "constant.character.escape.aeos"
            }
          ]
        },
        {
          "begin": "`",
          "end": "`",
          "name": "string.quoted.template.aeos",
          "patterns": [
            {
              "match": "\\\\[\\`\\\\]",
              "name": "constant.character.escape.aeos"
            },
            { "include": "#expressions" }
          ]
        },
        {
          "match": "/[a-zA-Z_][a-zA-Z0-9_/.-]*(?:/[a-zA-Z_][a-zA-Z0-9_/.-]*)*",
          "name": "string.regexp.path.aeos"
        },
        {
          "match": ":[a-zA-Z_][a-zA-Z0-9_-]*",
          "name": "constant.other.symbol.aeos"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "begin": "/\\*",
          "end": "\\*/",
          "name": "comment.block.aeos"
        },
        {
          "match": "(//|#).*$",
          "name": "comment.line.aeos"
        }
      ]
    }
  },
  "uuid": "b2c3d4e5-f6a7-8901-bcde-f12345678901"
}
