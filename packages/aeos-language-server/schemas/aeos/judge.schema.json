{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aeos.ai/schemas/judge.schema.json",
  "title": "AEOS Judge Configuration",
  "description": "Schema for AEOS Judge configuration. The Judge evaluates execution quality, security, and compliance by scoring evidence against rules and gates. It determines whether execution results pass or fail quality thresholds.",
  "type": "object",
  "required": [
    "$id",
    "name",
    "version",
    "rules"
  ],
  "properties": {
    "$id": {
      "type": "string",
      "pattern": "^[a-zA-Z][a-zA-Z0-9._-]*$",
      "description": "Unique identifier for the judge configuration."
    },
    "name": {
      "type": "string",
      "description": "Human-readable name for this judge configuration."
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(-[a-zA-Z0-9.]+)?$",
      "description": "Semantic version string (semver)."
    },
    "description": {
      "type": "string",
      "description": "Description of this judge configuration."
    },
    "enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether the judge is active."
    },
    "min_score": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 10.0,
      "default": 9.0,
      "description": "Minimum passing score (0-10). Scores below this fail the judge evaluation."
    },
    "min_confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "default": 0.8,
      "description": "Minimum confidence level for judge decisions."
    },
    "deterministic_first": {
      "type": "boolean",
      "default": true,
      "description": "Run deterministic rules before LLM-based evaluation for faster results."
    },
    "fail_fast": {
      "type": "boolean",
      "default": false,
      "description": "Stop evaluation on first failing rule instead of collecting all failures."
    },
    "rules": {
      "type": "array",
      "description": "List of evaluation rules. Rules are evaluated in order.",
      "items": {
        "type": "object",
        "required": ["name", "category", "score_weight", "check"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Rule name for identification."
          },
          "description": {
            "type": "string",
            "description": "Description of what this rule evaluates."
          },
          "category": {
            "type": "string",
            "enum": [
              "quality",
              "security",
              "compliance",
              "evidence_integrity",
              "correctness",
              "completeness",
              "performance",
              "safety",
              "governance"
            ],
            "description": "Category of evaluation."
          },
          "score_weight": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 1.0,
            "description": "Weight of this rule in the overall score. Sum of weights should equal 1.0."
          },
          "check": {
            "type": "object",
            "description": "Check configuration for this rule.",
            "oneOf": [
              {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["deterministic"]
                  },
                  "condition": {
                    "type": "string",
                    "description": "Expression that evaluates to true/false."
                  },
                  "expected_value": {},
                  "actual_field": {
                    "type": "string",
                    "description": "Field path to check in evidence."
                  },
                  "operator": {
                    "type": "string",
                    "enum": ["equals", "not_equals", "contains", "matches", "exists", "in", "gt", "gte", "lt", "lte"],
                    "description": "Comparison operator."
                  }
                },
                "required": ["type", "condition"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["llm_judged"]
                  },
                  "prompt": {
                    "type": "string",
                    "description": "Custom prompt for LLM evaluation."
                  },
                  "criteria": {
                    "type": "string",
                    "description": "Evaluation criteria description."
                  },
                  "rubric": {
                    "type": "object",
                    "description": "Scoring rubric.",
                    "properties": {
                      "scale": {
                        "type": "string",
                        "enum": ["0-10", "1-5", "1-3", "pass_fail"],
                        "default": "0-10"
                      },
                      "levels": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "properties": {
                            "score": { "type": "number" },
                            "label": { "type": "string" },
                            "description": { "type": "string" }
                          },
                          "additionalProperties": false
                        },
                        "description": "Scoring level descriptions."
                      }
                    },
                    "additionalProperties": false
                  }
                },
                "required": ["type", "criteria"],
                "additionalProperties": false
              },
              {
                "type": "object",
                "required": ["type"],
                "properties": {
                  "type": {
                    "type": "string",
                    "enum": ["evidence_check"]
                  },
                  "evidence_type": {
                    "type": "string",
                    "description": "Type of evidence to check."
                  },
                  "must_exist": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether the evidence must exist."
                  },
                  "must_be_complete": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether the evidence must have all required fields."
                  },
                  "hash_verified": {
                    "type": "boolean",
                    "default": true,
                    "description": "Whether the evidence hash must be verified."
                  }
                },
                "required": ["type", "evidence_type"],
                "additionalProperties": false
              }
            ]
          },
          "pass_score": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 10.0,
            "default": 10.0,
            "description": "Score for passing this rule."
          },
          "fail_score": {
            "type": "number",
            "minimum": 0.0,
            "maximum": 10.0,
            "default": 0.0,
            "description": "Score for failing this rule."
          },
          "block_on_fail": {
            "type": "boolean",
            "default": false,
            "description": "Whether failure of this rule should block execution entirely."
          },
          "required_evidence": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Required evidence types for this rule to evaluate."
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "gates": {
      "type": "array",
      "description": "Gates are hard checks that can block execution regardless of score.",
      "items": {
        "type": "object",
        "required": ["name", "condition"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Gate name."
          },
          "description": {
            "type": "string",
            "description": "Description of the gate."
          },
          "condition": {
            "type": "string",
            "description": "Condition that triggers this gate."
          },
          "action": {
            "type": "string",
            "enum": ["block", "warn", "require_approval"],
            "default": "block",
            "description": "Action when the gate condition is met."
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "high", "critical"],
            "default": "high",
            "description": "Severity of the gate."
          },
          "message": {
            "type": "string",
            "description": "Message displayed when the gate triggers."
          }
        },
        "additionalProperties": false
      }
    },
    "scoring": {
      "type": "object",
      "description": "Scoring configuration.",
      "properties": {
        "aggregation": {
          "type": "string",
          "enum": ["weighted_average", "minimum", "maximum", "geometric_mean"],
          "default": "weighted_average",
          "description": "Method for aggregating rule scores."
        },
        "passing_threshold": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 10.0,
          "default": 9.0,
          "description": "Score threshold for passing."
        },
        "curve": {
          "type": "string",
          "enum": ["linear", "logarithmic", "exponential"],
          "default": "linear",
          "description": "Scoring curve."
        }
      },
      "additionalProperties": false
    },
    "reporting": {
      "type": "object",
      "description": "Reporting configuration for judge results.",
      "properties": {
        "generate_report": {
          "type": "boolean",
          "default": true,
          "description": "Whether to generate a judge report."
        },
        "report_format": {
          "type": "string",
          "enum": ["json", "html", "markdown"],
          "default": "json",
          "description": "Report output format."
        },
        "report_path": {
          "type": "string",
          "description": "Path pattern for judge reports."
        },
        "include_evidence_summary": {
          "type": "boolean",
          "default": true,
          "description": "Include evidence summary in the report."
        },
        "include_remediation": {
          "type": "boolean",
          "default": true,
          "description": "Include remediation suggestions for failed rules."
        }
      },
      "additionalProperties": false
    },
    "enterprise_gates": {
      "type": "object",
      "description": "Enterprise compliance gates.",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false,
          "description": "Whether enterprise gates are enabled."
        },
        "require_audit_trail": {
          "type": "boolean",
          "default": true,
          "description": "Require complete audit trail for all actions."
        },
        "require_security_review": {
          "type": "boolean",
          "default": false,
          "description": "Require security review for high-risk actions."
        },
        "require_compliance_approval": {
          "type": "boolean",
          "default": false,
          "description": "Require compliance officer approval for regulated actions."
        }
      },
      "additionalProperties": false
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata.",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
