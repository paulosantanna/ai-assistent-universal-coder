{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CHIEF STAFF Evaluation Rubric Schema",
  "description": "Validates the 10-criterion rubric evaluation result",
  "type": "object",
  "required": ["evaluation_iteration", "scores", "overall_score", "passed", "findings"],
  "properties": {
    "evaluation_iteration": {
      "type": "object",
      "required": ["iteration", "timestamp", "artifacts_evaluated"],
      "properties": {
        "iteration": { "type": "integer", "minimum": 1, "maximum": 10 },
        "timestamp": { "type": "string", "format": "date-time" },
        "artifacts_evaluated": { "type": "array", "items": { "type": "string" } }
      }
    },
    "scores": {
      "type": "object",
      "required": [
        "layer_coverage", "data_dictionary", "diagram_correctness",
        "evidence_traceability", "zero_hallucination", "stakeholder_views",
        "html_interactivity", "improvement_plan", "output_structure", "professionalism"
      ],
      "patternProperties": {
        ".*": { "type": "number", "minimum": 0, "maximum": 10 }
      }
    },
    "overall_score": { "type": "number", "minimum": 0, "maximum": 10 },
    "passed": { "type": "boolean" },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "issue", "severity"],
        "properties": {
          "criterion": { "type": "string" },
          "issue": { "type": "string" },
          "evidence_ref": { "type": "string" },
          "severity": { "type": "string", "enum": ["critical", "major", "minor"] }
        }
      }
    },
    "remediation_required": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
