{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AEOS Agent Contract",
  "type": "object",
  "required": [
    "agent_id",
    "role",
    "objective",
    "scope"
  ],
  "properties": {
    "agent_id": {
      "type": "string"
    },
    "role": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "scope": {
      "type": "string"
    },
    "allowed_actions": {
      "type": "array"
    },
    "forbidden_actions": {
      "type": "array"
    },
    "evidence_requirements": {
      "type": "array"
    }
  }
}