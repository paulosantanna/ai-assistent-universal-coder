{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AEOS Checkpoint",
  "type": "object",
  "required": [
    "checkpoint_id",
    "objective",
    "phase",
    "next_action"
  ],
  "properties": {
    "checkpoint_id": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "phase": {
      "type": "string"
    },
    "completed_tasks": {
      "type": "array"
    },
    "pending_tasks": {
      "type": "array"
    },
    "evidence": {
      "type": "array"
    },
    "risks": {
      "type": "array"
    },
    "next_action": {
      "type": "string"
    }
  }
}